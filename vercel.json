{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "BASE_PATH=/ PORT=3000 NODE_ENV=production pnpm --filter @workspace/viorelvar-market run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "artifacts/viorelvar-market/dist/public",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/version.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/viorelvar-project.tar.gz",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" },
        { "key": "Content-Type", "value": "application/gzip" },
        { "key": "Content-Disposition", "value": "attachment; filename=viorelvar-project.tar.gz" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://your-api-host.example.com/api/:path*" },
    { "source": "/((?!api/|assets/|version\\.json|viorelvar-project\\.tar\\.gz|favicon\\.svg|opengraph\\.jpg|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
